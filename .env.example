# Copy to .env and fill in. Henry settings are prefixed HENRY_; provider API
# keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, ...) are unprefixed — the app loads
# this file into the process environment at startup so provider SDKs find them.
# Optional host port for docker compose Postgres. Keep this in sync with
# HENRY_DATABASE_URL when overriding it.
HENRY_DB_PORT=5432
HENRY_DATABASE_URL=postgresql+asyncpg://henry:henry@localhost:5432/henry
HENRY_SLACK_BOT_TOKEN=xoxb-...
HENRY_SLACK_APP_TOKEN=xapp-...
HENRY_DEFAULT_MODEL=anthropic:claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
HENRY_GITHUB_TOKEN=ghp_...
# Scope tool calls to one repository when the model omits owner/repo ("owner/repo")
HENRY_GITHUB_DEFAULT_REPO=
HENRY_WEB_SEARCH_PROVIDER=tavily
HENRY_WEB_SEARCH_API_KEY=
HENRY_LITELLM_BASE_URL=
HENRY_MAX_RUN_USD=1.00
HENRY_SANDBOX_IMAGE=henry-sandbox:base
