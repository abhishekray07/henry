FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        nodejs \
        npm \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-kernel.txt /opt/henry_kernel/requirements-kernel.txt
RUN pip install --no-cache-dir -r /opt/henry_kernel/requirements-kernel.txt

COPY kernel_protocol.py kernel_entry.py /opt/henry_kernel/

WORKDIR /workspace
